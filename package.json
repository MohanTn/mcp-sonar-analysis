{
  "name": "mcp-sonar-analysis",
  "version": "0.1.0",
  "description": "Local, server-free Sonar-grade static analysis (bugs, vulnerabilities, code smells, security hotspots) for TS/TSX and C# repos, exposed via MCP and CLI for Claude Code hook integration.",
  "license": "MIT",
  "type": "module",
  "main": "dist/mcp/server.js",
  "bin": {
    "mcp-sonar-analysis-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r src/dashboard/public dist/dashboard/public",
    "lint": "eslint . --ext .ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@typescript-eslint/parser": "^8.0.0",
    "better-sqlite3": "^12.10.1",
    "commander": "^12.0.0",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globby": "^14.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
